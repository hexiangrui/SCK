[
  {"id":"ht_001","type":"single_choice","question":"根据AQ 2068，矿山提升系统应每（ ）进行一次日常检查。","options":[{"key":"A","text":"班"},{"key":"B","text":"日"},{"key":"C","text":"周"},{"key":"D","text":"月"}],"answer":["B"],"explanation":"提升系统每日检查。","source":{"document":"AQ 2068-2019","article":"4.1","quote":"提升系统应每日进行一次日常检查"}},
  {"id":"ht_002","type":"single_choice","question":"根据AQ 2070，井下无轨运人车辆应配备（ ）。","options":[{"key":"A","text":"车载灭火器"},{"key":"B","text":"自救器"},{"key":"C","text":"急救包"},{"key":"D","text":"卫星电话"}],"answer":["A"],"explanation":"无轨运人车辆必须配备灭火器。","source":{"document":"AQ 2070-2019","article":"5.3","quote":"无轨运人车辆应配备车载灭火器"}},
  {"id":"ht_003","type":"single_choice","question":"提升机应装设（ ），超速15%时自动断电并安全制动。","options":[{"key":"A","text":"限速保护"},{"key":"B","text":"过卷保护"},{"key":"C","text":"过速保护"},{"key":"D","text":"过负荷保护"}],"answer":["C"],"explanation":"过速保护在超速15%时动作。","source":{"document":"AQ 2068-2019","article":"5.1","quote":"应装设过速保护装置"}},
  {"id":"ht_004","type":"true_false","question":"井下无轨运人车辆可以不配备安全防护顶篷。","options":[{"key":"A","text":"正确"},{"key":"B","text":"错误"}],"answer":["B"],"explanation":"必须配备防护顶篷。","source":{"document":"AQ 2070-2019","article":"5.1","quote":"应配备安全防护顶篷"}},
  {"id":"ht_005","type":"fill_blank","question":"提升钢丝绳应___至少进行一次定期检测检验。","options":null,"answer":["每半年"],"explanation":"钢丝绳每半年检测一次。","source":{"document":"AQ 2068-2019","article":"6.2","quote":"每半年至少进行一次定期检测检验"}},
  {"id":"ht_006","type":"single_choice","question":"特种设备使用登记应在使用前或使用后（ ）日内办理。","options":[{"key":"A","text":"10"},{"key":"B","text":"15"},{"key":"C","text":"30"},{"key":"D","text":"60"}],"answer":["C"],"explanation":"特种设备法规定30日内。","source":{"document":"特种设备安全法","article":"第三十三条","quote":"投入使用前或者投入使用后三十日内办理使用登记"}},
  {"id":"ht_007","type":"multi_choice","question":"提升系统定期检测检验应包括（ ）。","options":[{"key":"A","text":"提升钢丝绳检测"},{"key":"B","text":"提升容器检测"},{"key":"C","text":"制动装置检测"},{"key":"D","text":"井架外观"}],"answer":["A","B","C"],"explanation":"钢丝绳、容器和制动装置是必检项目。","source":{"document":"AQ 2068-2019","article":"6.1","quote":"包括提升钢丝绳、提升容器、制动装置等"}},
  {"id":"ht_008","type":"single_choice","question":"提升人员的罐笼顶部应设置可打开的（ ）。","options":[{"key":"A","text":"观察窗"},{"key":"B","text":"安全门"},{"key":"C","text":"逃生口"},{"key":"D","text":"通风口"}],"answer":["C"],"explanation":"罐笼顶部须设逃生口。","source":{"document":"GB 16423-2020","article":"6.3.4.3","quote":"罐笼顶部应设置可以打开的逃生口"}},
  {"id":"ht_009","type":"single_choice","question":"提升钢丝绳的安全系数，专为升降人员的不应小于（ ）。","options":[{"key":"A","text":"7"},{"key":"B","text":"7.5"},{"key":"C","text":"9"},{"key":"D","text":"6"}],"answer":["C"],"explanation":"升降人员钢丝绳安全系数不低于9。","source":{"document":"GB 16423-2020","article":"6.3.2.4","quote":"专为升降人员的提升钢丝绳安全系数不应小于9"}},
  {"id":"ht_010","type":"single_choice","question":"提升机过卷保护装置应在提升容器超过正常卸载位置（ ）m时动作。","options":[{"key":"A","text":"0.3"},{"key":"B","text":"0.5"},{"key":"C","text":"1.0"},{"key":"D","text":"1.5"}],"answer":["B"],"explanation":"过卷保护在超过卸载位置0.5m时动作。","source":{"document":"AQ 2068-2019","article":"5.2","quote":"过卷保护应在提升容器超过正常卸载位置0.5m时动作"}},
  {"id":"ht_011","type":"single_choice","question":"特种设备使用单位应配备（ ），负责特种设备安全管理工作。","options":[{"key":"A","text":"操作工"},{"key":"B","text":"特种设备安全管理人员"},{"key":"C","text":"电工"},{"key":"D","text":"任何人员"}],"answer":["B"],"explanation":"须配备专（兼）职安全管理人员。","source":{"document":"特种设备安全法","article":"第三十二条","quote":"应当配备特种设备安全管理人员"}},
  {"id":"ht_012","type":"true_false","question":"提升钢丝绳在1个捻距内断丝面积达到钢丝总面积的5%时，必须更换。","options":[{"key":"A","text":"正确"},{"key":"B","text":"错误"}],"answer":["A"],"explanation":"断丝达5%必须更换。","source":{"document":"AQ 2068-2019","article":"7.1","quote":"断丝面积达到钢丝总面积的5%时必须更换"}},
  {"id":"ht_013","type":"fill_blank","question":"提升机应装设___，当提升容器接近井口时发出减速信号并自动减速。","options":null,"answer":["减速信号装置"],"explanation":"减速信号装置在接近井口时自动报警减速。","source":{"document":"AQ 2068-2019","article":"5.3","quote":"提升机应装设减速信号装置"}},
  {"id":"ht_014","type":"single_choice","question":"井下无轨运人车辆应在投入使用前进行（ ），合格后方可使用。","options":[{"key":"A","text":"简单检查"},{"key":"B","text":"安全性能检测检验"},{"key":"C","text":"外观检查"},{"key":"D","text":"试驾"}],"answer":["B"],"explanation":"投入前须进行安全性能检测检验。","source":{"document":"AQ 2070-2019","article":"4.1","quote":"应在投入使用前进行安全性能检测检验"}},
  {"id":"ht_015","type":"single_choice","question":"特种设备存在严重事故隐患，无改造、维修价值的，使用单位应当（ ）。","options":[{"key":"A","text":"继续使用"},{"key":"B","text":"报废并注销登记"},{"key":"C","text":"封存"},{"key":"D","text":"转让"}],"answer":["B"],"explanation":"严重隐患设备须报废注销。","source":{"document":"特种设备安全法","article":"第四十八条","quote":"应当报废，并向原登记部门办理注销"}},
  {"id":"ht_016","type":"multi_choice","question":"提升系统安全保护装置包括（ ）。","options":[{"key":"A","text":"过卷保护"},{"key":"B","text":"过速保护"},{"key":"C","text":"限速保护"},{"key":"D","text":"温度保护"}],"answer":["A","B","C"],"explanation":"过卷、过速、限速是三大核心保护装置。","source":{"document":"AQ 2068-2019","article":"5.1","quote":"包括过卷保护、过速保护和限速保护装置"}},
  {"id":"ht_017","type":"true_false","question":"特种设备安全技术档案应保存至设备报废后5年。","options":[{"key":"A","text":"正确"},{"key":"B","text":"错误"}],"answer":["B"],"explanation":"安全技术档案须长期保存。","source":{"document":"特种设备安全法","article":"第三十五条","quote":"特种设备安全技术档案应当长期保存"}}
